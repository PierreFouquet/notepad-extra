{
  "productName": "Notepad Extra",
  "version": "0.4.0",
  "identifier": "io.github.PierreFouquet.NotepadExtra",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "src-tauri/dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all",
    "category": "Utility",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/PierreFouquet/notepad-extra",
    "publisher": "Pierre Fouquet",
    "copyright": "Copyright © Pierre Fouquet. Distributed under the GNU GPL v3 or later.",
    "shortDescription": "Small, fast, fully offline text and code editor",
    "longDescription": "Notepad Extra is a small, fast, fully offline text and code editor for Windows, macOS and Linux, built with Rust and Tauri and inspired by Notepad++. It offers tabbed editing, syntax highlighting for 80+ languages, find/replace/go-to-line, word wrap, editor zoom and light/dark themes, and preserves each file's original line endings on save.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "desktopTemplate": "packaging/linux/io.github.PierreFouquet.NotepadExtra.desktop",
        "files": {
          "/usr/share/metainfo/io.github.PierreFouquet.NotepadExtra.metainfo.xml": "packaging/linux/io.github.PierreFouquet.NotepadExtra.metainfo.xml",
          "/usr/share/man/man1/notepad-extra.1": "packaging/linux/notepad-extra.1",
          "/usr/share/icons/hicolor/32x32/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/64x64/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/64x64.png",
          "/usr/share/icons/hicolor/128x128/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/128x128@2x.png"
        }
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3"
        ],
        "desktopTemplate": "packaging/linux/io.github.PierreFouquet.NotepadExtra.desktop",
        "files": {
          "/usr/share/metainfo/io.github.PierreFouquet.NotepadExtra.metainfo.xml": "packaging/linux/io.github.PierreFouquet.NotepadExtra.metainfo.xml",
          "/usr/share/man/man1/notepad-extra.1": "packaging/linux/notepad-extra.1",
          "/usr/share/icons/hicolor/32x32/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/64x64/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/64x64.png",
          "/usr/share/icons/hicolor/128x128/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/io.github.PierreFouquet.NotepadExtra.png": "icons/128x128@2x.png"
        }
      }
    }
  },
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Notepad Extra",
        "width": 900,
        "height": 640,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}